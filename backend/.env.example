# Required — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides (defaults shown)
# SOLVR_OPUS_MODEL=claude-opus-4-8
# SOLVR_HAIKU_MODEL=claude-haiku-4-5
# SOLVR_DB_PATH=solvr.db
# SOLVR_CORS_ORIGINS=*
# SOLVR_MAX_BODY_BYTES=12582912

# Strongly recommended before deploying anywhere public — without this, any
# anonymous internet request can hit /solve and /practice and spend your
# Anthropic credits. Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# The mobile app must send the same value as EXPO_PUBLIC_BACKEND_API_KEY.
# SOLVR_APP_KEY=

# Optional — only used if both are set (hard handwritten-math OCR fallback;
# not yet wired into the pipeline, Claude vision handles OCR today)
# MATHPIX_APP_ID=
# MATHPIX_APP_KEY=
