# RevenueCat API keys — get these from app.revenuecat.com
REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Points the app at the real backend (see backend/README.md). Leave unset to
# run fully offline against the local mock in src/lib/mockApi.ts.
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Must match the backend's SOLVR_APP_KEY exactly once the backend has one
# configured, or every request 401s. Not a real secret from the client's
# perspective — it ships inside the built app — see backend/README.md § Security.
# EXPO_PUBLIC_BACKEND_API_KEY=
